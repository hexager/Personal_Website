---
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';

interface Props {
  pageTitle: string;
  description?: string;
  ogImage?: string;
}

const { 
  pageTitle,
  description = 'Siddhanth Methil — CS undergraduate and ML researcher. Portfolio, projects, and research notes on Federated Learning, Computer Vision, and more.',
  ogImage,
} = Astro.props;

const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: '~/HOME' },
  { href: '/projectblog', label: '~/WORK' },
  { href: '/about', label: '~/ABOUT' },
  { href: '/notes', label: '~/NOTES' },
];

function isActive(linkHref: string, currentPath: string): boolean {
  if (linkHref === '/') return currentPath === '/';
  return currentPath.startsWith(linkHref);
}
---

<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead title={pageTitle} description={description} ogImage={ogImage} />
  </head>
  
  <body class="bg-background text-zinc-400 min-h-screen flex flex-col selection:bg-accent/20 selection:text-white overflow-x-hidden">
    
    <!-- TOP BAR -->
    <header class="w-full px-6 py-4 flex justify-between items-center border-b border-white/5">
      <div class="flex items-center gap-3">
        <div class="w-2 h-2 bg-accent rounded-full animate-pulse"></div>
        <a href="/" class="font-mono text-sm font-bold text-zinc-100 tracking-widest hover:text-accent transition-colors">
          SID.METHIL//Hexager<span class="text-zinc-600"> // RSRCH</span>
        </a>
      </div>
      <div class="hidden md:block font-mono text-xs text-zinc-600">
        SYS.READY
      </div>
    </header>

    <!-- MAIN CONTENT-->
    <main class="flex-1 w-full max-w-5xl mx-auto px-6 py-12 md:py-20">
      <slot />
    </main>

    <!-- NAVIGATION BAR-->
    <nav class="sticky bottom-0 z-50 w-full bg-background/80 backdrop-blur-md border-t border-white/10">
      <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
        
        <div class="flex items-center gap-6 font-mono text-sm">
          {navLinks.map(link => (
            <a 
              href={link.href} 
              class={`transition-colors duration-200 ${
                isActive(link.href, currentPath)
                  ? 'text-accent'
                  : 'text-zinc-400 hover:text-accent'
              }`}
            >
              {link.label}
            </a>
          ))}
        </div>

        <div class="hidden sm:flex items-center gap-2 text-xs text-zinc-600">
          <span> COORD: 13.35N, 74.79E </span>
        </div>
      </div>
    </nav>

  </body>
</html>

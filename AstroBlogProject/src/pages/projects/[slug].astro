---
import { getCollection } from 'astro:content';
import TerminalLayout from '../../layouts/TerminalLayout.astro';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const projects = await getCollection('project');
  return projects.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const { 
  title, 
  description, 
  status = 'completed', 
  stack = [], 
  links = {}, 
  image, 
  type = 'project', 
  priority = 99,
  pubDate
} = entry.data;

const statusColor = status === 'in-progress' ? 'text-amber-400' : 'text-emerald-400';
---

<TerminalLayout pageTitle={`LOGS // ${title}`}>
  
  <article class="max-w-5xl mx-auto">
    
    <header class="mb-12 border-b border-white/10 pb-12">
      <div class="flex flex-wrap items-center gap-4 mb-6 font-mono text-xs text-zinc-500 uppercase tracking-widest">
        <a href="/projectblog" class="hover:text-accent transition-colors">← BACK_TO_GRID</a>
        <span class="text-zinc-700">|</span>
        <span class="text-accent">[{type}]</span>
        <span class={`flex items-center gap-2 ${statusColor} border border-white/5 px-2 py-1 bg-white/5 rounded-sm`}>
          <div class={`w-1.5 h-1.5 rounded-full bg-current ${status === 'in-progress' ? 'animate-pulse' : ''}`}></div>
          {status}
        </span>
      </div>

      <h1 class="text-4xl md:text-6xl font-bold text-zinc-100 mb-6 tracking-tight leading-tight">
        {title}
      </h1>

      <p class="text-xl text-zinc-400 leading-relaxed max-w-3xl mb-8">
        {description}
      </p>
      <!-- Had to go searching on how to get this logo, took raw svg code-->
      <div class="flex flex-wrap gap-4">
        {links?.github && (
          <a href={links.github} target="_blank" class="flex items-center gap-2 px-5 py-2.5 bg-zinc-100 text-zinc-900 hover:bg-white transition-all font-mono text-sm font-bold tracking-tight">
             <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            SOURCE_CODE
          </a>
        )}
        {links?.paper && (
          <a href={links.paper} target="_blank" class="flex items-center gap-2 px-5 py-2.5 bg-zinc-900 border border-zinc-700 hover:border-accent text-zinc-300 hover:text-white transition-all font-mono text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            READ_PAPER
          </a>
        )}
      </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 mb-20">
      
      <div class="lg:col-span-2 space-y-8">
        {image && (
          <div class="border border-white/10 bg-zinc-900 overflow-hidden">
            <Image src={image} alt={title} class="w-full h-auto" />
          </div>
        )}
        
        <div class="prose prose-invert prose-zinc max-w-none prose-headings:font-bold prose-headings:tracking-tight prose-a:text-accent prose-img:rounded-sm prose-pre:bg-zinc-900 prose-pre:border prose-pre:border-white/10">
          <Content />
        </div>
      </div>

      <!-- SIDEBAR -->
      <aside class="space-y-8 h-fit lg:sticky lg:top-8">
        
        <div class="border border-white/10 bg-zinc-900/50 p-6 backdrop-blur-sm">
          <h3 class="font-mono text-[10px] text-zinc-500 uppercase tracking-widest mb-4 border-b border-white/5 pb-2">
            DEPLOYMENT_STACK
          </h3>
          <div class="flex flex-wrap gap-2">
            {stack.map(tech => (
              <span class="text-xs font-mono text-zinc-300 bg-zinc-800 px-2 py-1 border border-white/5">
                {tech}
              </span>
            ))}
          </div>
        </div>

        <div class="border border-white/10 bg-zinc-900/50 p-6 backdrop-blur-sm">
          <h3 class="font-mono text-[10px] text-zinc-500 uppercase tracking-widest mb-4 border-b border-white/5 pb-2">
            METADATA
          </h3>
          <ul class="space-y-4 font-mono text-xs text-zinc-400">
            <li class="flex justify-between items-center">
              <span>TIMELINE</span>
              <span class="text-zinc-200">
                {pubDate ? new Date(pubDate).toLocaleDateString('en-US', { month: 'short', year: 'numeric' }) : 'N/A'}
              </span>
            </li>
            <li class="flex justify-between items-center">
              <span>CLASS</span>
              <span class="text-zinc-200 uppercase">{type}</span>
            </li>
            <li class="flex justify-between items-center">
              <span>AUTH</span>
              <span class="text-zinc-200">SID_METHIL</span>
            </li>
          </ul>
        </div>

      </aside>
    </div>

  </article>
</TerminalLayout>

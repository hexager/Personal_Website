---
import TerminalLayout from '../layouts/TerminalLayout.astro';
import SparseCubeCanvas from '../components/SparseCube.jsx'; // <--- The new component

const pageTitle = "Sid Methil // CS Undergrad · ML Research";
const description = "Siddhanth Methil — CS undergraduate and ML researcher building computation-efficient and data-efficient models. Portfolio, projects, and research notes.";
---

<TerminalLayout pageTitle={pageTitle} description={description}>
  <SparseCubeCanvas client:load />

  <!-- 2. Main Content (Centered and floating above) -->
  <section class="relative z-10 flex flex-col justify-center min-h-[80vh] space-y-12 pointer-events-none">
    <div class="space-y-4 text-center md:text-left md:pl-12">
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-black/40 border border-white/10 rounded-full backdrop-blur-md">
         <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></div>
         <span class="font-mono text-[10px] text-zinc-400 tracking-widest uppercase">
           Terminally Online
         </span>
      </div>

      <h1 class="font-bold text-zinc-100 tracking-tighter leading-none mix-blend-difference">
        <span class="block text-6xl md:text-9xl">SID METHIL</span>
        <span class="block text-xl md:text-3xl mt-3 md:mt-4 tracking-[0.2em] text-transparent bg-clip-text bg-gradient-to-r from-zinc-400 to-zinc-600 font-mono">
          CS UNDERGRAD · ML RESEARCH
        </span>
      </h1>
      
      <p class="text-xl md:text-2xl text-zinc-400 max-w-2xl font-light leading-relaxed mix-blend-difference">
        Building models which are computation-efficient and data-efficient.
      </p>
    </div>

    <div class="flex flex-wrap gap-4 pt-4 md:pl-12 pointer-events-auto">
      <a href="/projectblog" class="group relative px-8 py-4 bg-zinc-100 text-zinc-950 font-bold font-mono text-sm tracking-tight hover:bg-white transition-all">
        EXPLORE_MODULES →
      </a>
      <a href="/about" class="px-8 py-4 border border-white/10 text-zinc-400 font-mono text-sm hover:text-white hover:border-white/30 transition-all bg-black/20 backdrop-blur-md">
        ACCESS_BIO
      </a>
    </div>

  </section>
</TerminalLayout>

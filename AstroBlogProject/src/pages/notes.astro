---
import { getCollection } from 'astro:content';
import TerminalLayout from '../layouts/TerminalLayout.astro';

const allNotes = await getCollection('notes', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

const sortedNotes = allNotes.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const pageTitle = "Knowledge Base // Notes";
const description = "Technical notes, essays, and field observations by Siddhanth Methil on machine learning, computer vision, and AI research.";
---

<TerminalLayout pageTitle={pageTitle} description={description}>
  
  <header class="mb-12 pl-6 border-l-2 border-zinc-700">
    <h1 class="text-4xl font-bold text-zinc-100 tracking-tighter mb-2">
      THEORY_ARCHIVE
    </h1>
    <p class="text-zinc-400 font-mono text-sm">
      Technical essays, observations, and field notes.
    </p>
  </header>

  <div class="w-full font-mono text-sm">
    
    <div class="hidden md:grid grid-cols-12 gap-4 pb-2 border-b border-zinc-800 text-zinc-500 uppercase tracking-widest text-xs mb-4 px-4">
      <div class="col-span-2">Date</div>
      <div class="col-span-7">File_Name</div>
      <div class="col-span-3 text-right">Tags</div>
    </div>

    <ul class="space-y-1">
      {sortedNotes.map((note) => (
        <li>
          <a href={`/notes/${note.slug}`} class="group grid grid-cols-1 md:grid-cols-12 gap-2 md:gap-4 items-baseline p-3 md:px-4 rounded-sm hover:bg-zinc-900 transition-colors border border-transparent hover:border-zinc-800">
            
            <!-- Date (Mobile: Small & Top) -->
            <div class="col-span-12 md:col-span-2 text-zinc-500 group-hover:text-zinc-400">
              {note.data.pubDate.toISOString().split('T')[0]}
            </div>

            <!-- Title (The "File Name") -->
            <div class="col-span-12 md:col-span-7 font-bold text-zinc-300 group-hover:text-accent transition-colors truncate">
              {note.data.title}
            </div>

            <!-- Tags (Right Aligned) -->
            <div class="col-span-12 md:col-span-3 flex flex-wrap gap-2 justify-end">
              {note.data.tags.slice(0, 3).map((tag) => (
                <span class="text-[10px] text-zinc-600 border border-zinc-800 px-1.5 py-0.5 bg-black/20 group-hover:border-zinc-700 group-hover:text-zinc-500">
                  #{tag}
                </span>
              ))}
            </div>
          </a>
        </li>
      ))}
    </ul>
    
    {sortedNotes.length === 0 && (
       <div class="text-zinc-600 italic px-4 py-8 text-center border border-dashed border-zinc-800">
         Directory is empty.
       </div>
    )}

  </div>

</TerminalLayout>
